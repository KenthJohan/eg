{
	"id": "sokol_imgui",
	"type": "package",
	"value": {
		"language": "c",
		"public": true,
		"use": []
	},
	"lang.c": {
		"c-standard": "c11",
		"export-symbols": true,
		"static": true,
		"defines": [
			"SOKOL_GLCORE"
		],
