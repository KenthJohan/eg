module app.signals

const INT8_MIN = -128
const INT8_MAX = 127


const TYPE_I32 = 5
const TYPE_FLOAT = 6

const CANID_ODRIVE_SET_VEL = 77
const CANLEN_ODRIVE_SET_VEL = 8

rxt {
	- eg.can.RxThread{dummy:0}
	bus1 {
		- eg.can.BusDescription{interface:"can0"}
	}
}


rxt.bus1.motor {
	- eg.can.Signal{canid:$CANID_ODRIVE_SET_VEL, type:$TYPE_FLOAT, len:$CANLEN_ODRIVE_SET_VEL, tx:0, byte_offset:0, min: $INT8_MIN, max: $INT8_MAX, gui_index:6}
}




