module app.signals

const INT8_MIN = -128
const INT8_MAX = 127




const NODE_ID = 1
const CANID_ODRIVE_SET_VEL = 77
const CANLEN_ODRIVE_SET_VEL = 8

rxt {
	- eg.can.RxThread{dummy:0}
	bus1 {
		- eg.can.BusDescription{interface:"can0"}
	}
}


rxt.bus1.motor {
	- eg.quantities.RangedF32{min: -1, max: 1, tx:0, tx:0}
	- eg.can.Signal{canid:$CANID_ODRIVE_SET_VEL, len:$CANLEN_ODRIVE_SET_VEL, byte_offset:0, gui_index:6}
}




