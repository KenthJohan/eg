module app.signals
using flecs.meta




rxt {
	- eg.can.RxThread{dummy:0}
	bus1 {
		- eg.can.BusDescription{interface:"can0"}
		o1 {
			- odrives.Odrive{NODE_ID:1, gui_index_start: 10}
		}
		o2 {
			- odrives.Odrive{NODE_ID:2, gui_index_start: 20}
		}
		o3 {
			- odrives.Odrive{NODE_ID:3, gui_index_start: 30}
		}
		o4 {
			- odrives.Odrive{NODE_ID:4, gui_index_start: 40}
		}
	}
}







