// paste it into the editor at https://flecs.dev/explorer
//
// To load this file yourself, call ecs_plecs_from_file("expressions.flecs");

using eg.quantities


// Plecs files can contain variables that can be referenced later on when 
// assigning values to components
const width = 200

// Variables and components can be assigned using expressions. Most arithmetic
// and conditional operators are supported.
const height = 100


Draw {
// Inherit this drawing entity to draw shapes and text
}


e0 : Draw {
	- (V2F32, Position){10, 10}
	- (V2F32, Rectangle){$width, $height}
	- (V4U8, Color){255, 0, 0, 255}

	e00 : Draw {
		- (V2F32, Position)
		- (V2F32, PositionRelative){5, 5}
		- Text{"This is the red box"}
		- (V4U8, Color){60, 100, 255, 255}
	}

	e01 : Draw {
		- (V2F32, Position)
		- (V2F32, PositionRelative){20, 20}
		- (V2F32, Rectangle){$width*2, $height/2}
		- (V4U8, Color){0, 255, 0, 255}

		e010 : Draw {
			- (V2F32, Position)
			- (V2F32, PositionRelative){5, 5}
			- Text{"This is the green box"}
			- (V4U8, Color){60, 100, 255, 255}
		}

		e011 : Draw {
			- (V2F32, Position)
			- Margin4{5,10,15,20}
			- (V2F32, Rectangle){$width*4, $height/4}
			- (V4U8, Color){0, 0, 255, 255}

			e0110 : Draw {
				- (V2F32, Position)
				- (V2F32, PositionRelative){5, 5}
				- Text{"This is the blue box"}
				- (V4U8, Color){60, 100, 255, 255}
			}

		}

	}

}