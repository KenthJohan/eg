using eg.quantities
using eg.gui
using flecs.meta




Prefab Draw {
// Inherit this drawing entity to draw shapes and text
}

Prefab HoverStyle {
	// Will watch if mouse is over this entity then add or remove GuiMouseOver
	- GuiWatchMouseOver
	- (ColorRGBA_V4U8, GuiMouseOver1){200,255,0,255}
}



with ZIndex, ColorRGBA_V4U8, Position_V2F32, PositionGlobal_V2F32 {
	yrdy : Draw, HoverStyle {
		- Position_V2F32{500,100}
		- Rectangle_V2F32{50, 50}
	}
	_ : Draw, HoverStyle {
		- Position_V2F32{10,10}
		- Rectangle_V2F32{400, 400}
		- (Position_V2F32, SpatialCursor){200, 200}
	}
}
