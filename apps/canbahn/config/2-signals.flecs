module app.signals
using flecs.meta

Enum NavMode {
	Moving :- (Constant, i32){1}
	Docking :- (Constant, i32){2}
}



rxt {
	- eg.can.RxThread{dummy:0}
	bus1 {
		- eg.can.BusDescription{interface:"can0"}
		navmode {
			- eg.quantities.RangedGeneric{kind:U32, min_u64:0, max_u64:10}
			- eg.can.Signal{canid:20, len:8, byte_offset:4, gui_index:4, gui_scope_name_parent:rxt.bus1, rxtx:3, component_rep: NavMode}
		}
	}
}







