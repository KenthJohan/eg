	"version": "0.2.0",
	"configurations": [
		{
			"name": "Launch ex5_websocks",
			"type": "cppdbg",
			"request": "launch",
			"stopAtEntry": false,
			"cwd": "${workspaceFolder}/apps/ex5_websocks",
			"environment": [
				{
					"name": "LD_LIBRARY_PATH",
					"value": "${workspaceFolder}/bin/x64-Linux-debug:${env:HOME}/bake/x64-Linux/debug/lib/"
				},
			],
			"program": "${workspaceFolder}/apps/ex5_websocks/bin/x64-Linux-debug/ex5_websocks",
			"args": [],
			"osx": {
				"MIMode": "lldb",
				"targetArchitecture": "arm64",
				"externalConsole": false,
			},
			"linux": {
				"externalConsole": false,
			}
		},
